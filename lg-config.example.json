{
  "_comment": "LicenseGuard Config — lg-config.json olarak kopyalayin ve degerleri doldurun",

  "WarnDaysBeforeExpiry": 30,

  "SnapshotPath": ".\\lg-snapshot.json",

  "EolCheck": true,

  "ScanBrowserExtensions": true,
  "ScanVsCodeExtensions": true,
  "ScanStartup": true,

  "Whitelist": [
    "InternalTool",
    "CompanyApp"
  ],

  "FlexLM": [
    {
      "Name": "MATLAB",
      "Server": "27000@license-server01"
    },
    {
      "Name": "ANSYS",
      "Server": "1055@ansys-lic.corp.local"
    }
  ],

  "SaaS": [
    {
      "Name": "GitHub API",
      "Endpoint": "https://api.github.com/rate_limit",
      "Header": "Authorization",
      "Key": "Bearer ghp_XXXXXXXXXXXXXXXXXXXX",
      "ExpectStatus": 200
    },
    {
      "Name": "Custom Internal API",
      "Endpoint": "https://api.yourcompany.com/health",
      "Header": "X-API-Key",
      "Key": "your-api-key-here",
      "ExpectStatus": 200
    }
  ],

  "Email": {
    "SmtpServer": "smtp.company.com",
    "Port": 587,
    "UseSsl": true,
    "From": "licenseguard@company.com",
    "To": ["it-team@company.com", "manager@company.com"],
    "Credential": {
      "User": "licenseguard@company.com",
      "Password": "your-smtp-password"
    }
  },

  "Webhook": {
    "Type": "teams",
    "Url": "https://your-org.webhook.office.com/webhookb2/XXXX/IncomingWebhook/YYYY/ZZZZ"
  },

  "_comment_webhook_slack": "Slack icin Type: 'slack', Url: Slack Incoming Webhook URL",

  "Jira": {
    "BaseUrl": "https://your-org.atlassian.net",
    "User": "jira-user@company.com",
    "Token": "your-jira-api-token",
    "Project": "IT",
    "IssueType": "Bug"
  },

  "Branding": {
    "CompanyName": "Acme Corp",
    "PrimaryColor": "#3b82f6"
  }
}
